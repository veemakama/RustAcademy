# =============================================================================
#  RustAcademy Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables marked as REQUIRED must be set for the application to start.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port number for the HTTP server (default: 4000)
PORT=4000

# Node environment: development | production | test (default: development)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Network Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# Stellar network to connect to: testnet | mainnet
# Use 'testnet' for development and testing, 'mainnet' for production
NETWORK=testnet

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# Supabase project URL (e.g., https://your-project.supabase.co)
# Get this from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=http://127.0.0.1:54321

# Supabase anonymous (public) key
# Get this from: Supabase Dashboard > Project Settings > API > Project API keys
# NOTE: Never commit actual keys to version control
SUPABASE_ANON_KEY=test-anon-key

# Stellar
STELLAR_NETWORK=testnet

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins in production.
# Example: https:// RustAcademy.to,https://app. RustAcademy.to
CORS_ALLOWED_ORIGINS=https:// RustAcademy.to,https://app. RustAcademy.to

# Vercel project slug. When set, all preview URLs matching
# https://<slug>-*.vercel.app are automatically allowed.
CORS_VERCEL_PROJECT= RustAcademy-frontend

METRICS_ENDPOINT_PROTECTED=false # Set to true in production
METRICS_ENDPOINT_TOKEN=your-secret-token # If protected

# Recurring Payments Configuration
RECURRING_PAYMENT_MAX_RETRY=3
RECURRING_PAYMENT_RETRY_BACKOFF_MS=60000
RECURRING_PAYMENT_NOTIFICATION_HOURS_BEFORE=24
STELLAR_SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Sentry Error Monitoring (Optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error reporting. Omit to disable Sentry.
# Get this from: Sentry Dashboard > Project Settings > Client Keys (DSN)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry environment (e.g., production, staging). Falls back to NODE_ENV.
SENTRY_ENVIRONMENT=development

# Sentry release identifier (helps track which version introduced a bug)
SENTRY_RELEASE= RustAcademy-backend@0.1.0

# Performance traces sample rate (0.0 to 1.0). Use lower values in production.
SENTRY_TRACES_SAMPLE_RATE=1.0

# Profiling sample rate (0.0 to 1.0). Use lower values in production.
SENTRY_PROFILES_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# Staging Environment Parity Configuration (Optional)
# -----------------------------------------------------------------------------

# Enable environment parity checks at startup (default: false)
ENV_PARITY_CHECK_ENABLED=false

# Production base URL for parity comparison (staging only)
PRODUCTION_BASE_URL=https://api. RustAcademy.to

# Enable shadow traffic mode for read endpoints (default: false)
# WARNING: Only enable in staging. Never enable in production.
SHADOW_TRAFFIC_ENABLED=false

# Shadow traffic sample rate (0.0 to 1.0, default: 0.1 = 10%)
SHADOW_TRAFFIC_SAMPLE_RATE=0.1

# Comma-separated list of read endpoints to shadow (default: /api/links,/api/transactions,/api/usernames)
SHADOW_TRAFFIC_ENDPOINTS=/api/links,/api/transactions,/api/usernames

# Enable safe test data seeding in staging (default: false)
# WARNING: Only enable in staging. Never enable in production.
STAGING_SEED_DATA_ENABLED=false

# Explicit environment name for parity tracking
# Options: development, staging, production, test
ENVIRONMENT_NAME=development

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Whether the reconciliation module is enabled (default: true)
# Should be true in production, can be false in local dev if Supabase is unavailable.
FEATURES_RECONCILIATION_ENABLED=true

# Whether the notifications module is enabled (default: true)
# Should be true in production, can be false in local dev if Supabase is unavailable.
FEATURES_NOTIFICATIONS_ENABLED=true

# Whether developer-only routes and modules are enabled (default: false)
# MUST be false in production. Can be true in local/staging for debugging.
FEATURES_DEVELOPER_ROUTES_ENABLED=false
